# systemd-notifier Configuration
# Copy this file to ~/.config/systemd-notifier/config.env and fill in your values

# Required: Your Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Your Telegram Chat ID (get from @userinfobot or via getUpdates API)
TELEGRAM_CHAT_ID=your_chat_id_here

# Notification Settings
# Set to "true" to enable, "false" to disable

# Notify when screen is locked
NOTIFY_ON_LOCK=true

# Notify when screen is unlocked
NOTIFY_ON_UNLOCK=false

# Notify when system is going to sleep
NOTIFY_ON_SLEEP=true

# Notify when system wakes up from sleep
NOTIFY_ON_WAKE=true

# Notify when system is shutting down
NOTIFY_ON_SHUTDOWN=true

# Timing Configuration

# How many seconds BEFORE the event to send the notification
# e.g., 10 = send notification 10 seconds before lock/sleep/shutdown
# e.g., 60 = send notification 1 minute before
PRE_EVENT_DELAY=10

# How long to wait for the Telegram API to respond (seconds)
NOTIFICATION_TIMEOUT=30

# Debounce Configuration

# Enable debouncing to prevent duplicate notifications
ENABLE_DEBOUNCE=true

# Minimum time between duplicate notifications (seconds)
DEBOUNCE_SECONDS=5

# Logging Configuration

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Advanced Settings (usually don't need to change these)

# Maximum retries for Telegram API
TELEGRAM_MAX_RETRIES=3

# Delay between retries (seconds)
TELEGRAM_RETRY_DELAY=2

# =============================================================================
# CUSTOM SCRIPTS
# =============================================================================
# Run custom scripts when events occur (executed asynchronously/non-blocking)
# Scripts receive environment variables: EVENT_TYPE, EVENT_HOSTNAME, EVENT_TIMESTAMP, EVENT_MESSAGE

# Example: Pause music on lock, resume on unlock
# CUSTOM_SCRIPT_LOCK=/home/user/scripts/pause-music.sh
# CUSTOM_SCRIPT_UNLOCK=/home/user/scripts/resume-music.sh

# Example: Backup before sleep/shutdown
# CUSTOM_SCRIPT_SLEEP=/home/user/scripts/backup-before-sleep.sh
# CUSTOM_SCRIPT_SHUTDOWN=/home/user/scripts/final-backup.sh

# CUSTOM_SCRIPT_LOCK=
# CUSTOM_SCRIPT_UNLOCK=
# CUSTOM_SCRIPT_SLEEP=
# CUSTOM_SCRIPT_WAKE=
# CUSTOM_SCRIPT_SHUTDOWN=

# =============================================================================
# NOTIFICATION TEMPLATES (HTML supported)
# =============================================================================
# Customize the Telegram message format. Leave empty for default format.
# Available variables: {emoji}, {event_type}, {hostname}, {timestamp}, {message}

# Minimal format:
# NOTIFICATION_TEMPLATE="{emoji} {event_type} on {hostname}"

# With icons only:
# NOTIFICATION_TEMPLATE="<b>{event_type}</b> {emoji}\n<i>{hostname}</i> • {timestamp}"

# JSON-style (for parsing):
# NOTIFICATION_TEMPLATE="`{{\"event\": \"{event_type}\", \"host\": \"{hostname}\", \"time\": \"{timestamp}\"}}`"

# Rich format with message:
# NOTIFICATION_TEMPLATE="📱 <b>System Event: {event_type}</b>\n\nHost: <code>{hostname}</code>\nTime: <code>{timestamp}</code>\nStatus: <i>{message}</i>"

# Table format:
# NOTIFICATION_TEMPLATE="<pre>\nEvent    │ {event_type}\n─────────┼────────────────\nHost     │ {hostname}\nTime     │ {timestamp}\nMessage  │ {message}\n</pre>"

# One-liner with URL:
# NOTIFICATION_TEMPLATE="<a href=\"https://logs.example.com/{hostname}\">{emoji}</a> {event_type} @ {hostname} [{timestamp}]"

NOTIFICATION_TEMPLATE=

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# Choose which notification backends to use: telegram, discord, or both

# Backend selection (default: telegram)
# Options: telegram, discord, both
BACKEND=telegram

# =============================================================================
# DISCORD WEBHOOK CONFIGURATION
# =============================================================================
# Uncomment and fill in to send notifications to Discord
# Get webhook URL from Discord: Server Settings > Integrations > Webhooks

# Discord webhook URL (required for Discord backend)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Display name for the bot in Discord (optional, default: "Systemd Notifier")
# DISCORD_USERNAME=Systemd Notifier

# Avatar URL for the bot (optional, uses default Discord avatar if not set)
# DISCORD_AVATAR_URL=https://example.com/avatar.png

# =============================================================================
# NETWORK MONITORING
# =============================================================================
# Monitor network connectivity events (WiFi, VPN, Ethernet, Internet)

# Enable network monitoring
ENABLE_NETWORK_MONITOR=false

# Event mode selection:
# - NOTIFY_ON_CRITICAL_NETWORK_EVENTS=true: Only VPN disconnect and Internet loss
# - NOTIFY_ON_ALL_NETWORK_EVENTS=true: Use individual toggles below
NOTIFY_ON_CRITICAL_NETWORK_EVENTS=true
NOTIFY_ON_ALL_NETWORK_EVENTS=false

# Individual event toggles (only used if NOTIFY_ON_ALL_NETWORK_EVENTS=true)
# WiFi events
NOTIFY_ON_WIFI_CONNECT=true
NOTIFY_ON_WIFI_DISCONNECT=false

# VPN events
NOTIFY_ON_VPN_CONNECT=false
NOTIFY_ON_VPN_DISCONNECT=true  # Always notifies (security critical)

# Ethernet events  
NOTIFY_ON_ETH_CONNECT=false
NOTIFY_ON_ETH_DISCONNECT=false

# Internet connectivity
NOTIFY_ON_INTERNET_LOST=true       # Link state lost (cable unplugged, WiFi disconnected)
NOTIFY_ON_INTERNET_UNREACHABLE=false  # Link up but cannot reach internet (requires ping)

# Network settings
NETWORK_DEBOUNCE_SECONDS=5         # Seconds to wait before notifying on disconnect
NETWORK_IGNORE_INTERFACES=lo,docker0,veth*  # Interfaces to ignore

# Internet reachability check settings (only used if NOTIFY_ON_INTERNET_UNREACHABLE=true)
CONNECTIVITY_CHECK_HOST=1.1.1.1    # Host to ping for reachability check
CONNECTIVITY_CHECK_INTERVAL=30     # Seconds between checks
