# systemd-notifier Configuration
# Copy this file to ~/.config/systemd-notifier/config.env and fill in your values

# Required: Your Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Your Telegram Chat ID (get from @userinfobot or via getUpdates API)
TELEGRAM_CHAT_ID=your_chat_id_here

# Notification Settings
# Set to "true" to enable, "false" to disable

# Notify when screen is locked
NOTIFY_ON_LOCK=true

# Notify when screen is unlocked
NOTIFY_ON_UNLOCK=false

# Notify when system is going to sleep
NOTIFY_ON_SLEEP=true

# Notify when system wakes up from sleep
NOTIFY_ON_WAKE=true

# Notify when system is shutting down
NOTIFY_ON_SHUTDOWN=true

# Timing Configuration

# How many seconds BEFORE the event to send the notification
# e.g., 10 = send notification 10 seconds before lock/sleep/shutdown
# e.g., 60 = send notification 1 minute before
PRE_EVENT_DELAY=10

# How long to wait for the Telegram API to respond (seconds)
NOTIFICATION_TIMEOUT=30

# Debounce Configuration

# Enable debouncing to prevent duplicate notifications
ENABLE_DEBOUNCE=true

# Minimum time between duplicate notifications (seconds)
DEBOUNCE_SECONDS=5

# Logging Configuration

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Advanced Settings (usually don't need to change these)

# Maximum retries for Telegram API
TELEGRAM_MAX_RETRIES=3

# Delay between retries (seconds)
TELEGRAM_RETRY_DELAY=2
